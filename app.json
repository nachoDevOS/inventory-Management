{
  "expo": {
    "name": "Inventory Management",
    "slug": "inventory-management",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F1F5F9"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.nachodevos.inventorymanagement"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "photosPermission": "La app necesita acceso a tus fotos para agregar imágenes a los artículos.",
          "cameraPermission": "La app necesita acceso a la cámara para tomar fotos de los artículos."
        }
      ],
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "fc97ab63-389e-44d8-8b38-c35db294a9ee"
      }
    }
  }
}
